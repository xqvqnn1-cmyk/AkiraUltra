{
  "name": "ChatMessage",
  "type": "object",
  "properties": {
    "content": {
      "type": "string",
      "description": "Message content"
    },
    "channel": {
      "type": "string",
      "enum": [
        "general",
        "recommendations",
        "spoilers",
        "seasonal",
        "off-topic"
      ],
      "default": "general"
    },
    "user_name": {
      "type": "string"
    },
    "user_email": {
      "type": "string"
    },
    "mentions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of mentioned user emails"
    }
  },
  "required": [
    "content",
    "channel"
  ]
}